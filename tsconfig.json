{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "#src/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": false,
    "noImplicitAny": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
